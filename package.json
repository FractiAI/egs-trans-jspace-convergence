    "transformer": "python scripts/e5_geometry_probe.py",
    "e5": "python scripts/e5_geometry_probe.py",
    "e1b": "node scripts/e1_baseline_probe.mjs",
    "e2b": "python scripts/e2_generalization_probe.py",
    "e7": "node scripts/temporal_precedence_probe.mjs",
    "e8": "node scripts/e8_content_precedence_probe.mjs",
    "e9": "python scripts/e9_survey_driver.py",
    "e9:model": "python scripts/e9_multi_model_survey.py",
    "snapshots": "node scripts/historical_commit_snapshots.mjs",
