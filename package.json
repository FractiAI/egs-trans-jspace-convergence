    "synthobs": "python scripts/run_synthobs_monitor.py",
    "synthobs:loop": "python scripts/run_synthobs_monitor.py --loop --interval 30 --ws 8765",
    "synthobs:test": "python scripts/test_synthobs_metric.py && python scripts/test_egs_spectrum.py",
