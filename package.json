{
  "name": "egs-trans-jspace-convergence",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "EGS-TRANS-2026-0710 · Frontier multi-model J-Space convergence",
  "repository": {
    "type": "git",
